# GitHub App credentials (store in key vault or sealed secret in production)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# AI provider: "anthropic" (default) or "bedrock"
CLAUDE_PROVIDER=anthropic

# Claude API credentials (when CLAUDE_PROVIDER=anthropic) — choose ONE:
#
# Option 1: Console API key (pay-as-you-go billing).
#   Safe for multi-tenant deployments.
#   Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=
#
# Option 2: Max/Pro subscription OAuth token (consumer billing).
#   Generate locally with: `claude setup-token`
#   Copy the printed sk-ant-oat... value below.
#
#   REQUIRED: ALLOWED_OWNERS must be set to a single-tenant value (e.g. your
#   own GitHub login) — startup will fail with a ToS guard error otherwise.
#   Serving other users' repos from your subscription quota violates the
#   Claude Agent SDK Note at https://code.claude.com/docs/en/agent-sdk/overview
# CLAUDE_CODE_OAUTH_TOKEN=

# Model override. Required when CLAUDE_PROVIDER=bedrock (Bedrock uses a different model ID
# format than the Anthropic API). Optional for anthropic — defaults to claude-opus-4-7
# when unset. Opus runs ~5x Sonnet cost per token; set CLAUDE_MODEL=claude-sonnet-4-6
# if cost-sensitive.
# Bedrock example:  us.anthropic.claude-sonnet-4-6
# Anthropic example: claude-opus-4-7
# CLAUDE_MODEL=claude-opus-4-7

# ──────────────────────────────────────────────────────────────────────────────
# Amazon Bedrock (when CLAUDE_PROVIDER=bedrock)
# ──────────────────────────────────────────────────────────────────────────────
# AWS_REGION=us-east-1

# Credential method 1: Local dev — AWS SSO profile
#   Run "le aws login -e dev" first to populate ~/.aws/sso/cache/
#   The Claude Code subprocess reads this via the AWS SDK credential chain automatically.
# AWS_PROFILE=default

# Credential method 2: Explicit access keys (CI/CD or non-SSO environments)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=    # optional, for temporary/assumed-role credentials

# Credential method 3: OIDC bearer token (e.g. GitHub Actions with aws-actions/configure-aws-credentials)
# AWS_BEARER_TOKEN_BEDROCK=

# Credential method 4: IAM Role / IRSA (Kubernetes production via AWS_WEB_IDENTITY_TOKEN_FILE)
#   No environment variables needed — credentials are injected automatically by the kubelet.

# Optional: override the Bedrock API endpoint (e.g. for VPC endpoints or cross-region inference)
# ANTHROPIC_BEDROCK_BASE_URL=

# ──────────────────────────────────────────────────────────────────────────────

# Context7 (optional - for up-to-date library docs, free key at context7.com/dashboard)
CONTEXT7_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Authorization (optional — restricts who can trigger the bot)
# ──────────────────────────────────────────────────────────────────────────────
# Comma-separated list of GitHub owner logins. If set, the bot only responds to
# events from repositories owned by one of these accounts. Case-insensitive.
# Leave empty/unset for no restriction (any installation of the GitHub App can
# trigger execution — only use this with ANTHROPIC_API_KEY or Bedrock).
#
# REQUIRED when using CLAUDE_CODE_OAUTH_TOKEN — enforced at startup; a missing
# allowlist will throw a ToS guard error. See the note in the Anthropic section
# above for why.
# ALLOWED_OWNERS=chrisleekr

# Repo checkout
CLONE_BASE_DIR=/tmp/bot-workspaces

# App configuration
TRIGGER_PHRASE=@chrisleekr-bot
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Execution tuning (optional — sensible defaults exist)
# MAX_CONCURRENT_REQUESTS=3
# AGENT_TIMEOUT_MS=600000
# AGENT_MAX_TURNS=200          # Override max Claude SDK turns (default: complexity-based or 50)
# CLONE_DEPTH=50
# CLAUDE_CODE_PATH=

# ──────────────────────────────────────────────────────────────────────────────
# Daemon orchestration (Phase 2+) — all optional, defaults preserve current
# inline behaviour. Only needed when AGENT_JOB_MODE is set to a non-inline value.
# ──────────────────────────────────────────────────────────────────────────────

# Dispatch mode: inline (default, current behaviour) | shared-runner | ephemeral-job | auto
# For daemon orchestration, change to: shared-runner
AGENT_JOB_MODE=inline

# Fallback when mode=auto and triage is inconclusive
# DEFAULT_DISPATCH_TARGET=shared-runner

# K8s namespace for ephemeral jobs
# JOB_NAMESPACE=github-app

# Container image for spawned jobs (defaults to own image tag)
# JOB_IMAGE=

# TTL for completed job pods (seconds)
# JOB_TTL_SECONDS=300

# Hard wall-clock ceiling on an isolated-job run (seconds). K8s enforces
# server-side via Job.spec.activeDeadlineSeconds; the app-side watcher also
# enforces this and, on timeout, deletes the Job, writes a
# status="timeout" execution row, and releases the in-flight slot. Keep
# strictly below the installation-token TTL (GitHub: 3600s).
# JOB_ACTIVE_DEADLINE_SECONDS=1800

# Poll interval for the server-side isolated-job completion watcher.
# JOB_WATCH_POLL_INTERVAL_MS=5000

# ClusterIP URL of the shared runner Service
# INTERNAL_RUNNER_URL=

# Data layer — required when AGENT_JOB_MODE is not 'inline'
# DATABASE_URL=postgres://bot:bot@localhost:5432/github_app
# VALKEY_URL=redis://localhost:6379

# WebSocket server port for daemon connections
# WS_PORT=3002

# Shared secret for daemon ↔ orchestrator WebSocket authentication
# Required when AGENT_JOB_MODE is not 'inline'
# WARNING: Change this to a strong random value in production (e.g. openssl rand -hex 32)
# DAEMON_AUTH_TOKEN=local-dev-token

# Per-job cost ceiling in USD
# JOB_MAX_COST_USD=80

# Shared runner internal authentication (ADR-011)
# SHARED_RUNNER_TOKEN=
# INTERNAL_RUNNER_TOKEN=

# Daemon connection settings
# HEARTBEAT_INTERVAL_MS=30000
# HEARTBEAT_TIMEOUT_MS=90000
# STALE_EXECUTION_THRESHOLD_MS=600000
# DAEMON_DRAIN_TIMEOUT_MS=300000
# JOB_MAX_RETRIES=3
# OFFER_TIMEOUT_MS=5000

# Daemon-side settings (used by scripts/run-daemon.sh)
# ORCHESTRATOR_URL=ws://localhost:3002/ws
# Resource floors for job acceptance (os.freemem on macOS undercounts — set to 0 for local dev)
# DAEMON_MEMORY_FLOOR_MB=512
# DAEMON_DISK_FLOOR_MB=1024
# DAEMON_UPDATE_STRATEGY=exit
# DAEMON_UPDATE_DELAY_MS=0
# DAEMON_EPHEMERAL=false

# Triage pre-classifier
# TRIAGE_ENABLED=true
# TRIAGE_MODEL=haiku-3-5
# TRIAGE_CONFIDENCE_THRESHOLD=1.0
# TRIAGE_MAX_TOKENS=256

# Max turns override by complexity class (scalar env vars, FR-008a)
# Complexity → maxTurns ladder (FR-008a). Each is independently tunable; the
# triage output's `complexity` field maps to one of the three. If triage is
# skipped, errors, or returns an unknown complexity, DEFAULT_MAXTURNS is used.
# TRIAGE_MAXTURNS_TRIVIAL=10
# TRIAGE_MAXTURNS_MODERATE=30
# TRIAGE_MAXTURNS_COMPLEX=50
# DEFAULT_MAXTURNS=30
# TRIAGE_TIMEOUT_MS=5000

# Isolated-job capacity back-pressure (US3, FR-018). When the in-flight count
# hits MAX_CONCURRENT_ISOLATED_JOBS, new dispatches enqueue on the pending
# list up to PENDING_ISOLATED_JOB_QUEUE_MAX, then reject.
# MAX_CONCURRENT_ISOLATED_JOBS=3
# PENDING_ISOLATED_JOB_QUEUE_MAX=20

# Local E2E testing (used by /local-e2e skill and scripts/test-webhook.sh)
# LOCAL_E2E_TEST_REPO=owner/repo
# LOCAL_E2E_TEST_ENTITY=1
