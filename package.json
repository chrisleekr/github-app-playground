{
  "name": "@chrisleekr/github-app-playground",
  "description": "A GitHub App that listens for @chrisleekr-bot mentions on PRs and issues, then autonomously responds using the Claude Agent SDK (@anthropic-ai/claude-agent-sdk) with MCP servers",
  "author": "Chris Lee <git@chrislee.kr>",
  "version": "1.1.0",
  "main": "dist/app.js",
  "bin": {
    "github-app-playground": "dist/app.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "github",
    "app",
    "playground",
    "claude-code-action",
    "anthropic",
    "claude-agent-sdk",
    "modelcontextprotocol",
    "mcp",
    "octokit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisleekr/github-app-playground.git"
  },
  "bugs": {
    "url": "https://github.com/chrisleekr/github-app-playground/issues"
  },
  "homepage": "https://github.com/chrisleekr/github-app-playground#readme",
  "engines": {
    "bun": ">=1.3.12"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "prepublishOnly": "bun run clean && NODE_ENV=production bun run build",
    "clean": "rm -rf dist",
    "build": "bun run scripts/build.ts",
    "dev": "bun run build && bun run --watch src/app.ts",
    "dev:ngrok": "ngrok http 3000",
    "start": "bun run dist/app.js",
    "test": "bash scripts/test-isolated.sh",
    "test:fast": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "audit:ci": "bun run scripts/audit-ci.ts",
    "check": "bun run typecheck && bun run lint && bun run format && bun run test",
    "dev:daemon": "bash scripts/run-daemon.sh",
    "dev:deps": "docker compose -f docker-compose.dev.yml up -d",
    "dev:deps:down": "docker compose -f docker-compose.dev.yml down",
    "docker:build": "docker build -t chrisleekr/github-app-playground:local . --progress=plain",
    "docker:run": "bun run docker:build && docker run -p 3000:3000 --env-file .env -v $HOME/.aws:/home/bun/.aws:ro --rm --name github-app-playground chrisleekr/github-app-playground:local",
    "prepare": "husky"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/webhooks": "13.9.1",
    "@octokit/webhooks-types": "^7.6.1",
    "octokit": "^4.1.4",
    "pino": "^9.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.11",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.86.1",
    "@hono/node-server": "1.19.13",
    "express-rate-limit": "8.3.2",
    "flatted": "3.4.2",
    "hono": "4.12.14",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "yaml": "2.8.3"
  }
}
